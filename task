
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>团队任务管理系统（云端互通版）</title>
<style>
:root{--text:#2c3e50;--text2:#7f8c8d;--r1:12px;--r2:16px;--shadow:0 2px 8px rgba(0,0,0,0.06)}
*{margin:0;padding:0;box-sizing:border-box;font-family:system-ui}
body{background:#f7f8fa;height:100vh;overflow:hidden}
.login{position:fixed;inset:0;background:#fff;display:grid;place-items:center;z-index:9999}
.login-card{background:#fff;border-radius:20px;padding:32px;width:380px;box-shadow:0 10px 40px rgba(0,0,0,0.08)}
.login-title{font-size:22px;font-weight:600;margin-bottom:24px;text-align:center}
.role-bar{display:flex;gap:10px;margin-bottom:16px}
.role{flex:1;padding:10px;text-align:center;border:1px solid #ddd;border-radius:10px;cursor:pointer}
.role.active{background:#eef5ff;border-color:#409eff}
input{width:100%;padding:12px 14px;border:1px solid #ddd;border-radius:10px;margin-bottom:12px}
button.login-btn{width:100%;padding:12px;background:#409eff;color:white;border:none;border-radius:10px;font-weight:500;cursor:pointer}
.main{display:grid;grid-template-columns:300px 300px 1fr;gap:16px;height:100vh;padding:16px}
.panel{background:#fff;border-radius:16px;box-shadow:var(--shadow);display:flex;flex-direction:column;overflow:hidden}
.panel-h{padding:16px;border-bottom:1px solid #eee}
.panel-title{font-size:16px;font-weight:600;margin-bottom:10px}
.add-row{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.add-row input{flex:1;min-width:120px;padding:8px 12px;border:1px solid #ddd;border-radius:10px}
.add-row button{padding:8px 12px;background:#409eff;color:white;border:none;border-radius:10px;white-space:nowrap}
.panel-body{flex:1;overflow-y:auto;padding:8px}
.item{padding:10px 12px;border-radius:8px;margin:4px 0;cursor:pointer}
.item:hover{background:#f4f7ff}
.item.active{background:#eef5ff;font-weight:500}
.task-card{background:#f9fafb;border-radius:12px;padding:12px;margin:8px;position:relative}
.task-top{display:flex;align-items:center;gap:8px}
.task-text{flex:1;font-size:14px}
.task-note{margin-top:8px;padding:8px;background:#fff;border-left:3px solid #409eff;border-radius:8px;font-size:12px;color:#555}
.task-assign{color:#409eff;font-size:12px;margin-left:8px}
.task-actions{display:flex;gap:6px;opacity:0}
.task-card:hover .task-actions{opacity:1}
.tab-bar{display:flex;gap:10px;padding:12px;border-bottom:1px solid #eee}
.tab{padding:6px 12px;border-radius:8px;cursor:pointer}
.tab.active{background:#eef5ff;font-weight:500}
.tab-body{display:none;flex:1;overflow-y:auto}
.tab-body.active{display:block}
.context{position:fixed;background:#fff;border-radius:8px;box-shadow:0 5px 20px rgba(0,0,0,0.1);z-index:9999;min-width:160px}
.context-item{padding:10px 14px;cursor:pointer}
.context-item:hover{background:#f4f7ff}
.emp-view .panel:nth-child(1),.emp-view .panel:nth-child(2){display:none}
.emp-view .main{grid-template-columns:1fr}
.emp-title{padding:20px;text-align:center;font-size:18px;font-weight:600}
</style>
</head>
<body>

<div class="login" id="loginBox">
  <div class="login-card">
    <div class="login-title">团队任务管理系统</div>
    <div class="role-bar">
      <div class="role active" data-role="admin">负责人</div>
      <div class="role" data-role="user">员工</div>
    </div>
    <input id="user" placeholder="用户名">
    <input id="pwd" placeholder="密码" type="password">
    <button class="login-btn" onclick="goLogin()">登录</button>
  </div>
</div>

<div id="ctxMenu" class="context" style="display:none"></div>

<div class="main">
  <div class="panel">
    <div class="panel-h">
      <div class="panel-title">📁 项目</div>
      <div class="add-row">
        <input id="projName" placeholder="项目名称">
        <button onclick="addProj()">新建</button>
      </div>
    </div>
    <div class="panel-body" id="projList"></div>
  </div>

  <div class="panel">
    <div class="panel-h">
      <div class="panel-title">📋 任务列表</div>
      <div class="add-row">
        <input id="listName" placeholder="列表名称">
        <button onclick="addList()">新建</button>
      </div>
    </div>
    <div class="panel-body" id="listBox"></div>
  </div>

  <div class="panel">
    <div class="tab-bar">
      <div class="tab active" onclick="showTab('all')">全部</div>
      <div class="tab" onclick="showTab('undo')">待办</div>
      <div class="tab" onclick="showTab('done')">已完成</div>
    </div>
    <div class="tab-body active" id="allTask"></div>
    <div class="tab-body" id="undoTask"></div>
    <div class="tab-body" id="doneTask"></div>
    <div class="add-row" style="padding:12px">
      <input id="taskTxt" placeholder="任务内容" style="flex:2">
      <input id="taskNote" placeholder="备注说明" style="flex:2">
      <select id="toUser"></select>
      <button onclick="addTask()">添加任务</button>
    </div>
  </div>
</div>

<script>
const API = "https://db.cloud.motrix.cn/v1";
const DB_KEY = "pk_7a1e209f40c445f2a1d78090f8a9b123";
let me = {role:"",name:""};
let projId = null, listId = null;
let tabNow = "all";

async function db(table, opt={}){
  const res = await fetch(API+"/"+table,{
    method:"POST",
    headers:{"Authorization":"Bearer "+DB_KEY,"Content-Type":"application/json"},
    body:JSON.stringify(opt)
  });
  return await res.json();
}

// 登录
document.querySelectorAll('.role').forEach(e=>{
  e.onclick=()=>{
    document.querySelectorAll('.role').forEach(i=>i.classList.remove('active'));
    e.classList.add('active');
  }
});
function goLogin(){
  const u=document.getElementById('user').value.trim();
  const p=document.getElementById('pwd').value.trim();
  const r=document.querySelector('.role.active').dataset.role;
  if(!u||!p)return alert('请填写');
  if(r==='admin'&&u==='admin'&&p==='123456'){
    me={role:'admin',name:u};
    document.getElementById('loginBox').style.display='none';
    initAdmin();
    loadAll();
    return;
  }
  if(r==='user'){
    me={role:'user',name:u};
    document.getElementById('loginBox').style.display='none';
    document.body.classList.add('emp-view');
    loadMyTask();
  }
}

// 负责人初始化
async function initAdmin(){
  const users = await db('users',{action:'get'});
  const sel = document.getElementById('toUser');
  sel.innerHTML = '<option value="">不分配</option>';
  users.data?.forEach(u=>{
    sel.innerHTML+=`<option value="${u.name}">${u.name}</option>`
  });
  renderProj();
}

// 项目
async function addProj(){
  const n=document.getElementById('projName').value.trim();
  if(!n)return;
  await db('proj',{action:'add',name:n});
  document.getElementById('projName').value='';
  renderProj();
}
async function renderProj(){
  const d=await db('proj',{action:'list'});
  const b=document.getElementById('projList');
  b.innerHTML=d.data?.map(p=>`
    <div class="item ${projId===p.id?'active':''}" onclick="selProj(${p.id})">${p.name}</div>
  `).join('')||'暂无项目';
}
function selProj(id){projId=id;listId=null;renderList();renderTask();}

// 列表
async function addList(){
  const n=document.getElementById('listName').value.trim();
  if(!n||!projId)return;
  await db('list',{action:'add',projId,name:n});
  document.getElementById('listName').value='';
  renderList();
}
async function renderList(){
  const d=await db('list',{action:'list',projId});
  const b=document.getElementById('listBox');
  b.innerHTML=d.data?.map(l=>`
    <div class="item ${listId===l.id?'active':''}" onclick="selList(${l.id})">${l.name}</div>
  `).join('')||'请先选项目';
}
function selList(id){listId=id;renderTask();}

// 任务
async function addTask(){
  const t=document.getElementById('taskTxt').value.trim();
  const n=document.getElementById('taskNote').value.trim();
  const to=document.getElementById('toUser').value;
  if(!t||!listId)return;
  await db('task',{action:'add',listId,text:t,note:n,to,done:0});
  document.getElementById('taskTxt').value='';
  document.getElementById('taskNote').value='';
  renderTask();
}

// 右键菜单
function showMenu(e,tid){
  e.preventDefault();
  const m=document.getElementById('ctxMenu');
  m.innerHTML=`
    <div class="context-item" onclick="setNote(${tid})">修改备注</div>
    <div class="context-item" onclick="delTask(${tid})">删除任务</div>
  `;
  m.style.display='block';
  m.style.left=e.clientX+'px';
  m.style.top=e.clientY+'px';
}
document.onclick=()=>document.getElementById('ctxMenu').style.display='none';

async function setNote(tid){
  const t=await db('task',{action:'get',id:tid});
  const n=prompt('备注说明',t.data?.note||'');
  if(n===null)return;
  await db('task',{action:'up',id:tid,note:n});
  renderTask();
}
async function delTask(tid){
  if(!confirm('删除？'))return;
  await db('task',{action:'del',id:tid});
  renderTask();
}

// 渲染任务
async function renderTask(){
  if(!listId||me.role!=='admin')return;
  const all=await db('task',{action:'list',listId});
  const ts=all.data||[];
  const a=document.getElementById('allTask');
  const u=document.getElementById('undoTask');
  const d=document.getElementById('doneTask');
  a.innerHTML=ts.map(x=>card(x)).join('');
  u.innerHTML=ts.filter(x=>!x.done).map(x=>card(x)).join('');
  d.innerHTML=ts.filter(x=>x.done).map(x=>card(x)).join('');
}
function card(x){
  return `
  <div class="task-card" oncontextmenu="showMenu(event,${x.id})">
    <div class="task-top">
      <input type="checkbox" ${x.done?'checked':''} onchange="toggle(${x.id},this.checked)">
      <div class="task-text">
        ${x.text}
        ${x.to?`<span class="task-assign">→ ${x.to}</span>`:''}
        ${x.note?`<div class="task-note">${x.note}</div>`:''}
      </div>
    </div>
  </div>`;
}
async function toggle(id,done){
  await db('task',{action:'up',id,done:done?1:0});
  renderTask();
}

// 员工查看自己任务
async function loadMyTask(){
  const all=await db('task',{action:'my',name:me.name});
  const t=all.data||[];
  const a=document.getElementById('allTask');
  a.innerHTML=`<div class="emp-title">👋 ${me.name} 的任务</div>`+t.map(x=>`
    <div class="task-card">
      <div class="task-text">
        ${x.text}
        ${x.note?`<div class="task-note">备注：${x.note}</div>`:''}
      </div>
    </div>
  `).join('');
}

// 切换标签
function showTab(t){
  tabNow=t;
  document.querySelectorAll('.tab').forEach(i=>i.classList.remove('active'));
  document.querySelectorAll('.tab-body').forEach(i=>i.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById(t+'Task').classList.add('active');
}

// 全局刷新
function loadAll(){renderProj();renderList();renderTask();}

// 初始化默认员工
(async()=>{
  const u=await db('users',{action:'get'});
  if(!u.data?.length){
    await db('users',{action:'add',name:'员工A'});
    await db('users',{action:'add',name:'员工B'});
    await db('users',{action:'add',name:'员工C'});
  }
})();
</script>
</body>
</html>
